{
  "name": "Angular-libs",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build:counto": "ng build angular2-counto --prod",
    "build:text-mask": "ng build angular2-text-mask --prod",
    "build:perfect-mask": "ng build ngx-perfect-scrollbar --prod",
    "build:all": "concurrently \"npm run build:counto\" \"npm run build:text-mask\" \"npm run build:perfect-mask\"",
    "watch": "ng build --watch --configuration development",
    "ng-update": "ng update @angular/core @angular/cli",
    "test": "ng test"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "rxjs": "~7.8.0",
    "signature_pad": "^2.3.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.23",
    "@angular/cli": "~20.3.23",
    "@angular/compiler-cli": "^20.3.18",
    "@types/jasmine": "~4.3.0",
    "@types/signature_pad": "^2.3.6",
    "concurrently": "^8.0.1",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ng-packagr": "^20.3.2",
    "typescript": "~5.9.3"
  },
  "whitelistedNonPeerDependencies": [
    "signature_pad"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awaismirza/angular-wrappers.git"
  },
  "author": {
    "name": "Awais Jamil",
    "email": "owaesmirza@gmail.com",
    "url": "https://github.com/awaismirza"
  }
}
